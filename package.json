{
  "name": "laravel-ia-doc",
  "displayName": "Laravel AI Doc",
  "description": "Analiza y documenta cambios de tu proyecto Laravel usando IA",
  "version": "0.0.1",
  "publisher": "Kevin-dev",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinBayona/laravel-ia-doc-plugin"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "laravel",
    "ai",
    "documentation",
    "git",
    "php"
  ],
  "activationEvents": [
    "onCommand:laravel-ai-doc.analizarProyecto"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "laravel-ai-doc.analizarProyecto",
        "title": "Laravel AI: Analizar cambios"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "laravel-ai-doc.analizarProyecto",
          "title": "Laravel AI: Analizar cambios",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "openai": "^6.27.0"
  }
}
